package com.tka.june26;

public class Product {

    // Product properties
    int id;
    String name;
    double price;
    int quantity;
    String category;

    // Parameterized Constructor
    public Product(int id, String name, double price, int quantity, String category) {

        this.id = id;
        this.name = name;
        this.price = price;
        this.quantity = quantity;
        this.category = category;
    }
}
